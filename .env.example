# Public console URL for canonical / Open Graph (no trailing slash)
# Production example: https://app.convosync.io
# VITE_APP_URL=http://localhost:3000

# Marketing site (apps/landing) — logged-out / and legal links
# Local: http://localhost:3001
# Production: https://convosync.io
VITE_LANDING_URL=http://localhost:3001

# Marketing analytics
VITE_GA4_MEASUREMENT_ID=G-1B0W0S40PK
# Step 2 — Google Tag Manager (optional; if set, configure GA4 inside GTM and remove GA4 env above)
# VITE_GTM_ID=GTM-XXXXXXX
# Step 3 — Meta Pixel (Events Manager → Pixel ID)
# VITE_META_PIXEL_ID=123456789012345
# Step 4 — Microsoft Clarity
# VITE_CLARITY_PROJECT_ID=abcdefghij
# VITE_ANALYTICS_DEBUG=true

# API (local or dev tunnel — must include /api suffix)
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000

# Meta / WhatsApp Embedded Signup (v4 — Facebook Login for Business configurations)
VITE_META_APP_ID=your_meta_app_id
# Business API — VITE_META_CONFIG_ID or VITE_META_CONFIGURATION_ID
VITE_META_CONFIG_ID=your_embedded_signup_config_id
# VITE_META_CONFIGURATION_ID=your_embedded_signup_config_id
# Coexistence — separate v4 config with WhatsApp Business App onboarding product
# VITE_META_WHATSAPP_CONFIG=your_whatsapp_business_app_embedded_signup_config_id
# Must match Meta → Facebook Login → Valid OAuth Redirect URIs exactly (no ?query)
# Production example: https://wabiz.classivo.app/integrations
VITE_META_EMBEDDED_REDIRECT_URI=http://localhost:3000/integrations
VITE_META_OAUTH_REDIRECT_URI=http://localhost:3000/manager
# Instagram connect — must match FB.login redirect_uri exactly
VITE_META_INSTAGRAM_REDIRECT_URI=http://localhost:3000/instagram/callback

# Dev auto-login (optional)
VITE_DEV_EMAIL=admin@convosync.io
VITE_DEV_PASSWORD=password12345678
